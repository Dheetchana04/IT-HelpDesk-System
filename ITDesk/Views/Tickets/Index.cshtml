@model Ticket

<h2>All Tickets</h2>

<a asp-action="Create" class="btn btn-success">New Ticket</a>

<table class="table mt-3">
    <tr>
        <th>Category</th>
        <th>Priority</th>
        <th>Status</th>
        <th>Action</th>
    </tr>

    @foreach (var t in Model)
    {
        <tr>
            <td>@t.Category</td>
            <td>@t.Priority</td>
            <td>@t.Status</td>
            <td>
                @if (User.IsInRole("Admin") || User.IsInRole("ITSupport"))
                {
                    <a asp-action="UpdateStatus" asp-route-id="@t.Id">
                        Update
                    </a>
                }
                else
                {
                    <span>-</span>
                }
            </td>

        </tr>
    }
</table>
